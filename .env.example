# Configure at least one provider. Never commit real keys.

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Anthropic Messages API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# Google Gemini generateContent API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# DeepSeek Chat Completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# Alibaba Cloud Model Studio / Qwen
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.5-flash
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Moonshot / Kimi
MOONSHOT_API_KEY=
KIMI_MODEL=kimi-k2.5
# KIMI_BASE_URL=https://api.moonshot.cn/v1/chat/completions

# xAI / Grok
XAI_API_KEY=
XAI_MODEL=grok-4.20-reasoning
# XAI_BASE_URL=https://api.x.ai/v1/chat/completions

# Optional beta access control. Users enter this token in the app's model settings.
AI_GATEWAY_TOKEN=

# Optional comma-separated cross-origin frontends, for example GitHub Pages.
# Same-origin Vercel deployments work without this setting.
AI_ALLOWED_ORIGINS=https://sirugao.github.io
